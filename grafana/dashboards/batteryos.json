{
  "title": "BatteryOS Platform",
  "uid": "batteryos-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["batteryos"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Prediction Throughput (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(batteryos_predictions_total[2m]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "sum by (chemistry) (rate(batteryos_predictions_total[2m]))",
          "legendFormat": "{{chemistry}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Prediction Latency (p50 / p95)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(batteryos_prediction_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(batteryos_prediction_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Auth Failures / Errors",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(batteryos_auth_failures_total[2m]))",
          "legendFormat": "auth failures",
          "refId": "A"
        },
        {
          "expr": "sum(rate(batteryos_errors_total[2m]))",
          "legendFormat": "unhandled errors",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Predictions by Chemistry",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (chemistry) (increase(batteryos_predictions_total[10m]))",
          "legendFormat": "{{chemistry}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Models Loaded",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 5 },
      "targets": [
        { "expr": "batteryos_models_loaded", "legendFormat": "", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "green" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active Fine-tune Jobs",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 5 },
      "targets": [
        { "expr": "batteryos_finetune_jobs_active", "legendFormat": "", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Predictions (all-time)",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(batteryos_predictions_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Auth Failures (1h)",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(increase(batteryos_auth_failures_total[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    }
  ]
}
